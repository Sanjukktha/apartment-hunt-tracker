# Copy to .env for local development, and set the same values in your Vercel
# project settings for production. Leave everything blank to run in local-only
# mode (localStorage, no sharing, no auto-fill).

# --- Frontend (safe to expose: the anon key is public by design) ---
# From Supabase: Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The public URL of the deployed site, used to build the deep links in the Excel
# export. Leave blank to fall back to the current page. Example:
# VITE_SITE_URL=https://apartment-hunt.vercel.app
VITE_SITE_URL=

# Site-wide access code (soft gate). When set, visitors must enter this code to
# add/edit/generate, or choose "I just want to view" for a read-only session.
# Leave blank to disable the gate (fully open). NOTE: this is bundled into the
# client, so it deters casual visitors but is not real security.
VITE_ACCESS_CODE=

# --- Backend only (NEVER exposed to the browser; no VITE_ prefix) ---
# Free key from https://openrouteservice.org/dev (email signup, no card).
# Powers the drive / walk / cycle distance and time auto-fill.
ORS_API_KEY=

# Google Maps Platform key with the Places API (New) enabled. Powers the
# "Start from a transit stop" anchor in the schedule generator (finds the
# nearest PATH / subway / train / bus stop). If left blank, the app falls back
# to the free but slower OpenStreetMap Overpass service.
GOOGLE_MAPS_API_KEY=
